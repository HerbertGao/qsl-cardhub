# QSL CardHub 云端查询与同步服务
# 使用前请先执行: npx wrangler d1 create qsl-sync
# 将返回的 database_id 填入下方 [[d1_databases]].database_id

name = "qsl-web-query-service"
main = "src/worker/index.js"
compatibility_date = "2024-01-01"

# 启用 workers.dev 子域名（设为 false 则仅通过自定义域名访问）
workers_dev = true

# 启用预览 URL（设为 false 可禁用）
preview_urls = true

# 静态资源目录（构建后的前端文件）
# binding 必填：worker 经 env.ASSETS 取静态资源并为 SPA 客户端路由（含 /t/<slug>/ 租户入口）
# 返回 index.html 内容；缺 binding 则 env.ASSETS 未定义、worker 的 SPA 回退失效、/t/<slug>/ 404。
[assets]
directory = "./public"
binding = "ASSETS"

# D1 数据库绑定（创建后填入 database_id）
[[d1_databases]]
binding = "DB"
database_name = "qsl-sync"
database_id = "<RUN_WRANGLER_D1_CREATE_AND_PASTE_ID_HERE>"

# KV 命名空间绑定（限流计数 + nonce 去重 + 防爬会话/PoW 存储）
# 创建命令：npx wrangler kv namespace create "RATE_LIMIT"
# 将返回的 id 填入下方
#
# 【硬部署前置】会话/PoW/配额/防重放依赖此 KV——与纯 IP 限流（KV 缺失 fail-open）不同，
# 会话相关端点在 KV 未绑定时 fail-closed（/api/session* 返 503、无有效会话的查询被拒），
# 绝不因缺 KV 静默放行无会话查询。务必绑定。
[[kv_namespaces]]
binding = "RATE_LIMIT"
id = "<RUN_WRANGLER_KV_CREATE_AND_PASTE_ID_HERE>"

# 环境变量（敏感信息请在 dashboard 或 wrangler secret 中配置）
[vars]
# API_KEY 用于 /ping 与 /sync 的 Bearer 校验，部署后通过 wrangler secret put API_KEY 设置

# DEFAULT_TENANT：本部署的默认租户 slug（非密钥、可入版本控制示例）。
#   - bare 入口（root `/`、不带 `/t/<slug>/` 前缀的 `/api/*`）以此值作租户上下文；
#     写入面 legacy `env.API_KEY` 兜底归属、微信 auth-callback 无 state 兜底亦取此值。
#   - 缺省（未配置或空串）回退 'bh2ro'（现网兼容）。「改配置文件即可换默认租户」的落点。
#   - 部署契约（关键）：其值【必须】== tenants 表里那条 active 默认租户的 slug；
#     不一致 → bare 查询面以未 seed 的 tenant_id 查询 → 静默空结果（非报错）。
#     详见 docs/web-query-service-deploy.md「阶段 4-B：查询面按租户路径路由」。
DEFAULT_TENANT = "bh2ro"

# ============================================================
# 微信服务号配置（可选）
# ============================================================
# 以下配置为可选，未配置时订阅收卡功能将自动禁用，查询功能不受影响。
#
# 启用订阅功能需配置：
#   - WECHAT_APPID: 微信服务号 AppID
#   - WECHAT_SECRET: 微信服务号 AppSecret
#
# 启用微信推送需额外配置：
#   - WECHAT_TEMPLATE_ID: 微信模板消息 ID
#
# 配置方式（推荐使用 secret 保护敏感信息）：
#   wrangler secret put WECHAT_APPID
#   wrangler secret put WECHAT_SECRET
#   wrangler secret put WECHAT_TEMPLATE_ID

# ============================================================
# 防爬会话 / PoW 配置（query-antibot-session）
# ============================================================
# 查询侧防爬：PoW 门票 + 短时会话（绑真实 IP+UA）+ 会话配额 + 会话专属动态签名。
# 需配置以下 Secret：
#
# SESSION_SECRET: 会话 token 的 HMAC-SHA256 密钥（仅服务端，必须保密）
#   - 生成：openssl rand -hex 32
#   - 仅经 Secret 注入，禁写入本文件 / [vars] / 任何版本控制文件：
#       wrangler secret put SESSION_SECRET
#   - 未配置 → 会话功能 fail-closed（/api/session* 与查询会话校验返 503）。
#   - 泄漏可伪造 token，但仍受「KV 必命中 session + IP/UA 绑定 + 配额」三重约束；
#     可轮换（轮换瞬间在途会话失效、客户端自动重走 PoW）。
#
# 已退役（不再使用，可清理残留 Secret）：
#   - CLIENT_SIGN_KEY：静态查询签名密钥，经 /api/config 明文下发=可公开值、对防爬零收益，
#     已由会话专属 sk 取代；/api/config 不再下发 sign_key。
#   - CAPTCHA_SECRET：算术验证码已移除（PoW 取代），不再需要。

# ============================================================
# 配置卫生说明（签名密钥与服务凭据）
# ============================================================
# 本服务的签名密钥与各服务凭据均按「配置卫生」口径管理：真实值禁止写入
# 纳入版本控制的文件（含本 .example、README 等），仅以占位符出现，靠
# Cloudflare Secret 或部署期注入提供。
#
# 顺丰 checkword（config/sf_express_default.toml）、SESSION_SECRET、CDN_ORIGIN_SECRET
# 处境对称——均被 .gitignore 忽略、真实值未进入 Git 历史、靠 CI/Secret 注入，
# 统一按配置卫生项管理。查询签名密钥已改为会话专属、短时的 sk（经 POST /api/session
# 响应下发），静态 CLIENT_SIGN_KEY 与 CAPTCHA_SECRET 已退役、不再下发。

# ============================================================
# CDN 真实客户端 IP 与限流配置（可选）
# ============================================================
# 仅当生产经阿里云 CDN（qsl.herbert-dev.cn）回源到 Cloudflare 源站
# （qsl.herbertgao.me）时才需要配置。它们决定「限流/防爬计数键」如何取真实
# 用户 IP；本组配置产物仅作限流计数键（抬高自动化批量调用成本），不用作
# 访问控制/鉴权判据。详见 docs/web-query-service-deploy.md 的「CDN 真实 IP
# 与限流」一节（含部署顺序硬约束与维护周期）。
#
# 信任信号 = 阿里云 CDN 注入的【密钥回源头 X-Origin-Auth】（非 IP 白名单——阿里云
# 回源 IP 动态分配、官方不建议固定白名单、查询接口还有带宽门槛，故改用密钥头）。
#
# 【部署顺序】① 阿里云 CDN「修改出站请求头」以覆盖语义注入 X-Origin-Auth: <密钥>
# （操作选「增加 + 不允许重复」或「替换」，使客户端伪造的同名头被覆盖）；回源协议
# 须为 HTTPS（密钥不走明文）。② 部署 worker。③ wrangler secret put CDN_ORIGIN_SECRET。
# ④ 经抓包证伪门证实 Ali-Cdn-Real-Ip 确被 CDN 覆写后，才配 CDN_REAL_IP_HEADER。
#
# CDN_ORIGIN_SECRET: 期望的 X-Origin-Auth 密钥值（机密，与阿里云回源头注入值一致）
#   - 生成：openssl rand -hex 32。仅经 Secret 注入，禁写入本文件 / 禁进 /api/config：
#       wrangler secret put CDN_ORIGIN_SECRET
#   - worker 用常量时间比对；请求带正确密钥 = 确来自 CDN → 采信受信真实 IP 头。
#   - 未配置/为空 → fail-safe：只信 CF-Connecting-IP、不采信任何注入头（CDN 路径
#     按 CDN 回源节点 IP 计数，粒度失真但不被绕过）。
#   - 应急轮换：阿里云改新值 → worker 改 secret（过渡期可临时同时接受新旧两值）。
#
# CDN_REAL_IP_HEADER: 受信真实 IP 头名（阿里云 CDN 写入真实用户 IP 的头）
#   - 【无内置默认】——未配置即 fail-safe 到 CF-Connecting-IP。禁止给它写默认值。
#   - 推荐值 Ali-Cdn-Real-Ip（阿里云默认携带、官方语义：单值、CDN 节点按 TCP 层
#     对端写入、为避免 X-Forwarded-For 伪造而设）；但「覆写而非透传」须经部署期
#     抓包证伪门实证后，才由运营者显式填入此项。
#   - 证实前保持未配置；CDN 侧配置变更后须重跑证伪门、变更需人工 sign-off。
#   - 经 [vars] 或 Secret 注入（示例，证实前勿填）：
#       wrangler secret put CDN_REAL_IP_HEADER
#     （或在 [vars] 中以 CDN_REAL_IP_HEADER = "Ali-Cdn-Real-Ip" 配置）

# ============================================================
# 网站备案信息配置（可选）
# ============================================================
# 配置后将在页面底部展示 ICP 备案和公安备案信息，仅当访问域名匹配时显示。
#
# SITE_FILING: JSON 字符串，包含以下字段：
#   - domain: 展示备案信息的域名（仅当 hostname 匹配时展示）
#   - icp: ICP 备案号文本
#   - police: 公安备案号文本
#   - police_code: 公安备案号纯数字编码（用于拼接 beian.mps.gov.cn 链接）
#
# 示例：
# [vars]
# SITE_FILING = '{"domain":"qsl.example.com","icp":"京ICP备XXXXXXX号-X","police":"京公网安备XXXXXXXXXXX号","police_code":"XXXXXXXXXXX"}'
