# QSL CardHub 云端查询与同步服务
# 使用前请先执行: npx wrangler d1 create qsl-sync
# 将返回的 database_id 填入下方 [[d1_databases]].database_id

name = "qsl-web-query-service"
main = "src/worker/index.js"
compatibility_date = "2024-01-01"

# 启用 workers.dev 子域名（设为 false 则仅通过自定义域名访问）
workers_dev = true

# 启用预览 URL（设为 false 可禁用）
preview_urls = true

# 静态资源目录（构建后的前端文件）
[assets]
directory = "./public"

# D1 数据库绑定（创建后填入 database_id）
[[d1_databases]]
binding = "DB"
database_name = "qsl-sync"
database_id = "<RUN_WRANGLER_D1_CREATE_AND_PASTE_ID_HERE>"

# KV 命名空间绑定（用于限流计数和 nonce 去重）
# 创建命令：npx wrangler kv namespace create "RATE_LIMIT"
# 将返回的 id 填入下方
[[kv_namespaces]]
binding = "RATE_LIMIT"
id = "<RUN_WRANGLER_KV_CREATE_AND_PASTE_ID_HERE>"

# 环境变量（敏感信息请在 dashboard 或 wrangler secret 中配置）
[vars]
# API_KEY 用于 /ping 与 /sync 的 Bearer 校验，部署后通过 wrangler secret put API_KEY 设置

# ============================================================
# 微信服务号配置（可选）
# ============================================================
# 以下配置为可选，未配置时订阅收卡功能将自动禁用，查询功能不受影响。
#
# 启用订阅功能需配置：
#   - WECHAT_APPID: 微信服务号 AppID
#   - WECHAT_SECRET: 微信服务号 AppSecret
#
# 启用微信推送需额外配置：
#   - WECHAT_TEMPLATE_ID: 微信模板消息 ID
#
# 配置方式（推荐使用 secret 保护敏感信息）：
#   wrangler secret put WECHAT_APPID
#   wrangler secret put WECHAT_SECRET
#   wrangler secret put WECHAT_TEMPLATE_ID

# ============================================================
# 验证码防护配置（可选）
# ============================================================
# 启用验证码防护需配置以下环境变量：
#
# CLIENT_SIGN_KEY: 前端请求签名密钥（用于生成前端请求签名）
#   - 经 /api/config 明文下发，按设计属可公开值（仅抬高脚本门槛）
#   - 但其真实值仍用 Secret 管理，避免写入版本控制：
#       wrangler secret put CLIENT_SIGN_KEY
#   - 不要写进本文件或 [vars]，本文件仅保留占位符/说明
#   - 注：改用 Secret 不改变它经 /api/config 面向公网的可见性，
#     也不提供查询签名绕过防护（真正闭合属后续阶段会话动态签名）
#
# CAPTCHA_SECRET: 验证码 token 签名密钥（仅服务端，不可公开）
#   - 用于生成和验证验证码 token 的 HMAC 签名
#   - 必须保密，用 Secret 配置：
#       wrangler secret put CAPTCHA_SECRET
#
# 配置方式（均用 Secret，禁止写入 [vars] 或本文件真实值）：
#   wrangler secret put CLIENT_SIGN_KEY
#   wrangler secret put CAPTCHA_SECRET

# ============================================================
# 配置卫生说明（签名密钥与服务凭据）
# ============================================================
# 本服务的签名密钥与各服务凭据均按「配置卫生」口径管理：真实值禁止写入
# 纳入版本控制的文件（含本 .example、README 等），仅以占位符出现，靠
# Cloudflare Secret 或部署期注入提供。
#
# 顺丰 checkword（config/sf_express_default.toml）与 CLIENT_SIGN_KEY
# （wrangler.toml）处境对称——均被 .gitignore 忽略、真实值未进入 Git 历史、
# 靠 CI/Secret 注入，统一按配置卫生项管理；CLIENT_SIGN_KEY 不因此被单独
# 定性为已泄漏（其经 /api/config 下发本属可公开值）。

# ============================================================
# CDN 真实客户端 IP 与限流配置（可选）
# ============================================================
# 仅当生产经阿里云 CDN（qsl.herbert-dev.cn）回源到 Cloudflare 源站
# （qsl.herbertgao.me）时才需要配置。它们决定「限流/防爬计数键」如何取真实
# 用户 IP；本组配置产物仅作限流计数键（抬高自动化批量调用成本），不用作
# 访问控制/鉴权判据。详见 docs/web-query-service-deploy.md 的「CDN 真实 IP
# 与限流」一节（含部署顺序硬约束与维护周期）。
#
# 【部署顺序硬约束】必须先在 Cloudflare 配好「源站 qsl.herbertgao.me 仅接受
# 阿里云回源段 / CF 的回源」（WAF/Firewall Rules）使其生效，再配下面的
# CDN_ORIGIN_CIDRS，最后经抓包证伪门证实后才配 CDN_REAL_IP_HEADER。顺序颠倒
# 会进入「白名单生效但可直连源站伪造头」的危险中间态（比都不配更糟）。
#
# CDN_ORIGIN_CIDRS: 阿里云 CDN 回源 IP 段白名单（逗号/空白分隔的 CIDR 串）
#   - 来源：阿里云 OpenAPI DescribeCdnBackSourceIp，或 CDN 控制台「回源 IP」
#     页面导出；禁止硬编码进代码，由部署期注入并定期维护（阿里云会调整）。
#   - 仅填【全局可路由的公网单播 IPv4】CIDR；私网/CGNAT(100.64.0.0/10)/
#     loopback/link-local/组播/保留/`/0`/非法前缀会被解析阶段一律丢弃（落进
#     白名单几乎一定是误配，会把大片来源当成可信 CDN = 采信伪造头的安全洞）。
#   - 宁缺勿宽 + 最小化：只填确属阿里云回源的段；废弃/过宽段须及时移除，
#     变更需人工 sign-off。
#   - 未配置/为空 → fail-safe：只信 CF-Connecting-IP、不采信任何注入头；此时
#     CDN 路径下限流按【CDN 回源节点 IP】计数（粒度失真但不被绕过）。
#   - 真实值不写死在本文件；经 [vars] 或 Secret 注入：
#       wrangler secret put CDN_ORIGIN_CIDRS
#     （或在生产 wrangler.toml 的 [vars] 中以 CDN_ORIGIN_CIDRS = "a.b.c.0/24,..." 配置）
#
# CDN_REAL_IP_HEADER: 受信真实 IP 头名（阿里云 CDN 写入真实用户 IP 的头）
#   - 【无内置默认】——未配置即视为「未证实覆写」=安全态，解析 fail-safe 到
#     CF-Connecting-IP、不读任何注入头。禁止给它写默认值（默认值会让部署即
#     采信某头、复活伪造态）。
#   - 推荐值 Ali-Cdn-Real-Ip（阿里云官方语义：单值、由 CDN 节点按 TCP 层对端
#     写入并覆盖客户端同名头）；但该「覆写而非透传」是单点信任根，必须经部署
#     期抓包证伪门实证该头名确被 CDN 覆写之后，才由运营者显式填入此项。
#   - 证实前保持未配置；CDN 侧配置变更后须重跑证伪门、变更需人工 sign-off。
#   - 真实值经证实后注入（示例，证实前勿填）：
#       wrangler secret put CDN_REAL_IP_HEADER
#     （或在 [vars] 中以 CDN_REAL_IP_HEADER = "Ali-Cdn-Real-Ip" 配置）

# ============================================================
# 网站备案信息配置（可选）
# ============================================================
# 配置后将在页面底部展示 ICP 备案和公安备案信息，仅当访问域名匹配时显示。
#
# SITE_FILING: JSON 字符串，包含以下字段：
#   - domain: 展示备案信息的域名（仅当 hostname 匹配时展示）
#   - icp: ICP 备案号文本
#   - police: 公安备案号文本
#   - police_code: 公安备案号纯数字编码（用于拼接 beian.mps.gov.cn 链接）
#
# 示例：
# [vars]
# SITE_FILING = '{"domain":"qsl.example.com","icp":"京ICP备XXXXXXX号-X","police":"京公网安备XXXXXXXXXXX号","police_code":"XXXXXXXXXXX"}'
